@model Pozdravlyator.Models.BirthdayPerson

<div class="container mt-4">

    <h1>Добавить день рождения</h1>

    <form asp-action="Create" enctype="multipart/form-data">

        <div class="mb-3">
            <label class="form-label">Имя</label>
            <input class="form-control" asp-for="FullName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Дата рождения</label>
            <input class="form-control" asp-for="BirthDate" type="date" />
        </div>

        <div class="mb-3">
            <label class="form-label">Фото (путь)</label>
            <input class="form-control" type="file" name="PhotoFile" />
        </div>

        <button class="btn btn-success" type="submit">
            Сохранить
        </button>

    </form>

</div>