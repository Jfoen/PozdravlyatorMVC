@model IEnumerable<Pozdravlyator.Models.BirthdayPerson>

<div class="container mt-4">

    <h1 class="mb-4">🎉 Дни рождения</h1>

    <table class="table table-striped table-hover">

        <thead>
            <tr>
                <th>Имя</th>
                <th>Дата рождения</th>
                <th>Действия</th>
            </tr>
        </thead>

        <tbody>
        @foreach (var item in Model)
        {
            var today = DateTime.Today;

            var isToday = item.BirthDate.Month == today.Month &&
                          item.BirthDate.Day == today.Day;

            var isSoon = new DateTime(today.Year, item.BirthDate.Month, item.BirthDate.Day)
                         <= today.AddDays(7);

            <tr class="@(isToday ? "table-danger" : isSoon ? "table-warning" : "")">

                <td>@item.FullName</td>
                <td>@item.BirthDate.ToShortDateString()</td>

                <td>
                    <a class="btn btn-sm btn-warning"
                       asp-action="Edit"
                       asp-route-id="@item.Id">
                        Редактировать
                    </a>

                <form asp-action="Delete"
                      asp-route-id="@item.Id"
                      method="post"
                      style="display:inline;">

                    <button type="submit" class="btn btn-sm btn-danger">
                        Удалить
                    </button>

                </form>
                </td>

                        <td>
            <img src="@item.PhotoPath"
                 alt="photo"
                 style="width:60px;height:60px;object-fit:cover;border-radius:50%;" />
        </td>

            </tr>
        }
        </tbody>

    </table>

</div>